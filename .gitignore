# Run outputs (generated, never commit)
outputs/

# Pipeline mode outputs — examples/<workspace>/fast/ and ursa/ are live run artifacts
examples/*/fast/
examples/*/ursa/

# URSA runtime scratch (created inside agent workspaces)
graph_store.sqlite
ursa_metrics/

# Agent-run logs
logs/

# ML data and model artifacts (generated; track structure via .gitkeep only)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
models/checkpoints/*
!models/checkpoints/.gitkeep
experiments/*
!experiments/.gitkeep
.claude/scheduled_tasks.lock
.claude/settings.local.json
